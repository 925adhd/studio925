# Web3Forms access key — used by the contact form (src/components/Contact.tsx)
# and the audit form (app/audit/content.tsx).
# Get a key at https://web3forms.com and set this in Vercel project env settings
# (and in a local .env.local for dev). Required at build time because Next.js
# bakes NEXT_PUBLIC_* vars into the client bundle.
NEXT_PUBLIC_WEB3FORMS_KEY=
